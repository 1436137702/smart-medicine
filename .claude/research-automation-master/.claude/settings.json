{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/meta_learn_hook.py",
            "timeout": 3000,
            "continueOnError": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__claude-flow__:*"
    ],
    "deny": []
  },
  "attribution": {
    "commit": "Co-Authored-By: ricet <ricet@research-automation>",
    "pr": "Generated with [ricet](https://github.com/lucafusarbassini/research-automation)"
  },
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "claude-flow": {
      "command": "npx",
      "args": [
        "claude-flow@v3alpha",
        "mcp",
        "serve"
      ]
    },
    "paper-search-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@openags/paper-search-mcp"
      ]
    },
    "arxiv-mcp-server": {
