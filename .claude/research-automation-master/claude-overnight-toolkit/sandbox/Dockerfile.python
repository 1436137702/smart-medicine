# =============================================================================
# Claude Agent Overnight Sandbox — Python/ML variant
# =============================================================================
# Use this for ML/data science projects (PyTorch, scikit-learn, etc.)
# No Docker-in-Docker — lighter image, faster to build.
#
# Base: Python 3.12 slim (Debian)
# Includes: Node.js, Claude CLI, git, matplotlib deps
# =============================================================================

FROM python:3.12-slim

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl git sudo procps coreutils tini gosu \
    # For matplotlib/plotting
    libgl1 libglib2.0-0 libsm6 libxrender1 libxext6 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (required for Claude CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI
RUN npm install -g @anthropic-ai/claude-code

# Create agent user
RUN groupadd -g 1000 agent \
    && useradd -m -u 1000 -g agent -s /bin/bash agent

# Create workspace and log directories
RUN mkdir -p /workspace /agent-logs \
    && chown -R agent:agent /workspace /agent-logs

# Copy entrypoint and utility scripts
COPY sandbox-entrypoint.sh /usr/local/bin/sandbox-entrypoint.sh
COPY watchdog.sh /usr/local/bin/watchdog.sh
RUN chmod +x /usr/local/bin/sandbox-entrypoint.sh /usr/local/bin/watchdog.sh

# Environment
ENV SANDBOX_TIMEOUT_HOURS=8 \
    WORKSPACE=/workspace \
    AGENT_LOGS=/agent-logs \
    HOME=/home/agent \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

ENTRYPOINT ["tini", "--", "/usr/local/bin/sandbox-entrypoint.sh"]
